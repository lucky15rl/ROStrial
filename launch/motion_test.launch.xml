<?xml version="1.0"?>
<launch>
  <let name="urdf_file"
    value="$(find-pkg-share athens_description)/urdf/athens.urdf" />

  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param name="robot_description"
      value="$(file-content $(var urdf_file))" type="str" />
  </node>

  <node pkg="rviz2" exec="rviz2"
    args="-d $(find-pkg-share athens_description)/config/config.rviz"/>

  <node pkg="tf2_ros" exec="static_transform_publisher"
    args="0.1 0 0.1 0 0 0 gripper_base_link tool_frame"/>

  <node pkg="athens_motion" exec="motion_generator"/>
</launch>
